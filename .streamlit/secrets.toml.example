# Streamlit secrets template
# Add your Gemini API key here when deploying to Streamlit Community Cloud.
# In the Streamlit Cloud dashboard: Settings → Secrets → paste the contents below.
#
# The app also accepts the API key directly via the UI text input,
# so this file is optional but recommended for a smoother user experience.

GEMINI_API_KEY = "your-gemini-api-key-here"
